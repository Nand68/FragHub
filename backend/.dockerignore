# Ignore node_modules (they will be installed in Docker)
node_modules

# Ignore dist folder (will be built in Docker)
dist

# Ignore local logs and temp files
*.log
*.tsbuildinfo

# Ignore environment files (provide them at runtime instead)
.env
.env.local

# Ignore IDE/editor files
.vscode
.idea

# Ignore OS files
.DS_Store

# Ignore git
.git
.gitignore

# Ignore documentation
README.md

# Ignore test files
**/*.test.ts
**/*.spec.ts